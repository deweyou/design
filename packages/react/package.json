{
  "name": "@deweyou-design/react",
  "version": "0.0.5",
  "description": "Reusable UI components for Deweyou UI.",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js",
      "default": "./dist/*/index.js"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "directory": "dist"
  },
  "scripts": {
    "build": "vp build && tsc -p tsconfig.build.json && node scripts/inject-css-imports.mjs && node scripts/concat-style.mjs && node ../infra/scripts/write-published-manifest.mjs .",
    "dev": "vp build --watch",
    "test": "vp test"
  },
  "dependencies": {
    "@ark-ui/react": "catalog:",
    "@deweyou-design/react-hooks": "workspace:*",
    "@deweyou-design/styles": "workspace:*",
    "classnames": "catalog:"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@tsdown/css": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "less": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
