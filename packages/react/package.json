{
  "name": "@deweyou-design/react",
  "version": "0.0.5",
  "description": "Reusable UI components for Deweyou UI.",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/button/index.d.ts",
      "import": "./dist/button/index.js",
      "default": "./dist/button/index.js"
    },
    "./popover": {
      "types": "./dist/popover/index.d.ts",
      "import": "./dist/popover/index.js",
      "default": "./dist/popover/index.js"
    },
    "./text": {
      "types": "./dist/text/index.d.ts",
      "import": "./dist/text/index.js",
      "default": "./dist/text/index.js"
    },
    "./menu": {
      "types": "./dist/menu/index.d.ts",
      "import": "./dist/menu/index.js",
      "default": "./dist/menu/index.js"
    },
    "./tabs": {
      "types": "./dist/tabs/index.d.ts",
      "import": "./dist/tabs/index.js",
      "default": "./dist/tabs/index.js"
    },
    "./checkbox": {
      "default": "./dist/checkbox/index.js",
      "import": "./dist/checkbox/index.js",
      "types": "./dist/checkbox/index.d.ts"
    },
    "./radio-group": {
      "default": "./dist/radio-group/index.js",
      "import": "./dist/radio-group/index.js",
      "types": "./dist/radio-group/index.d.ts"
    },
    "./switch": {
      "default": "./dist/switch/index.js",
      "import": "./dist/switch/index.js",
      "types": "./dist/switch/index.d.ts"
    },
    "./select": {
      "default": "./dist/select/index.js",
      "import": "./dist/select/index.js",
      "types": "./dist/select/index.d.ts"
    },
    "./dialog": {
      "default": "./dist/dialog/index.js",
      "import": "./dist/dialog/index.js",
      "types": "./dist/dialog/index.d.ts"
    },
    "./tooltip": {
      "default": "./dist/tooltip/index.js",
      "import": "./dist/tooltip/index.js",
      "types": "./dist/tooltip/index.d.ts"
    },
    "./toast": {
      "default": "./dist/toast/index.js",
      "import": "./dist/toast/index.js",
      "types": "./dist/toast/index.d.ts"
    },
    "./scroll-area": {
      "default": "./dist/scroll-area/index.js",
      "import": "./dist/scroll-area/index.js",
      "types": "./dist/scroll-area/index.d.ts"
    },
    "./pagination": {
      "default": "./dist/pagination/index.js",
      "import": "./dist/pagination/index.js",
      "types": "./dist/pagination/index.d.ts"
    },
    "./package.json": "./package.json",
    "./style.css": "./dist/style.css"
  },
  "publishConfig": {
    "directory": "dist"
  },
  "scripts": {
    "build": "vp build && tsc -p tsconfig.build.json && node scripts/concat-style.mjs && node ../infra/scripts/write-published-manifest.mjs .",
    "dev": "vp build --watch",
    "test": "vp test"
  },
  "dependencies": {
    "@deweyou-design/react-hooks": "workspace:*",
    "@deweyou-design/styles": "workspace:*",
    "classnames": "catalog:"
  },
  "devDependencies": {
    "@ark-ui/react": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@tsdown/css": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "less": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
