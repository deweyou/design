{
  "name": "@deweyou-ui/hooks",
  "version": "0.0.0",
  "description": "Reusable React hooks for Deweyou UI packages and apps.",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "directory": "dist"
  },
  "scripts": {
    "build": "vp pack && node ../utils/scripts/write-published-manifest.mjs .",
    "dev": "vp pack --watch",
    "test": "vp test"
  },
  "dependencies": {
    "@deweyou-ui/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:"
  }
}
