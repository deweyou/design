{
  "name": "@deweyou-ui/components",
  "version": "0.0.0",
  "description": "Reusable UI components for Deweyou UI.",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "vp build && tsc -p tsconfig.build.json",
    "dev": "vp build --watch",
    "test": "vp test"
  },
  "dependencies": {
    "@deweyou-ui/hooks": "workspace:*",
    "@deweyou-ui/styles": "workspace:*",
    "classnames": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@tsdown/css": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "less": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}
