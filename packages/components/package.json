{
  "name": "@deweyou-ui/components",
  "version": "0.0.0",
  "description": "Reusable UI components for Deweyou UI.",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/button/index.d.ts",
      "import": "./dist/button/index.js",
      "default": "./dist/button/index.js"
    },
    "./popover": {
      "types": "./dist/popover/index.d.ts",
      "import": "./dist/popover/index.js",
      "default": "./dist/popover/index.js"
    },
    "./text": {
      "types": "./dist/text/index.d.ts",
      "import": "./dist/text/index.js",
      "default": "./dist/text/index.js"
    },
    "./menu": {
      "types": "./dist/menu/index.d.ts",
      "import": "./dist/menu/index.js",
      "default": "./dist/menu/index.js"
    },
    "./tabs": {
      "types": "./dist/tabs/index.d.ts",
      "import": "./dist/tabs/index.js",
      "default": "./dist/tabs/index.js"
    },
    "./package.json": "./package.json",
    "./style.css": "./dist/style.css"
  },
  "publishConfig": {
    "directory": "dist"
  },
  "scripts": {
    "build": "vp build && tsc -p tsconfig.build.json && node ../utils/scripts/write-published-manifest.mjs .",
    "dev": "vp build --watch",
    "test": "vp test"
  },
  "dependencies": {
    "@ark-ui/react": "catalog:",
    "@deweyou-ui/hooks": "workspace:*",
    "@deweyou-ui/styles": "workspace:*",
    "classnames": "catalog:"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@tsdown/css": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "less": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
