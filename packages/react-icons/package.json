{
  "name": "@deweyou-design/react-icons",
  "version": "0.0.5",
  "description": "React icon components for Deweyou UI — thin wrapper over @tabler/icons-react.",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./src/index.ts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "directory": "dist"
  },
  "scripts": {
    "build": "vp pack && node ../infra/scripts/write-published-manifest.mjs .",
    "dev": "vp pack --watch",
    "generate": "node ./scripts/generate-icons.mjs",
    "test": "vp test"
  },
  "dependencies": {
    "@tabler/icons-react": "^3",
    "tdesign-icons-svg": "catalog:"
  },
  "devDependencies": {
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:"
  }
}
