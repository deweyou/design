{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "paths": {
      "@deweyou-ui/icons": ["../../packages/icons/src/index.ts"],
      "@deweyou-ui/icons/*": ["../../packages/icons/src/exports/*.ts"],
      "@deweyou-ui/components": ["../../packages/components/src/index.ts"],
      "@deweyou-ui/components/*": ["../../packages/components/src/*/index.tsx"],
      "@deweyou-ui/styles": ["../../packages/styles/src/index.ts"],
      "@deweyou-ui/styles/*": ["../../packages/styles/src/*"]
    }
  },
  "include": ["src"]
}
